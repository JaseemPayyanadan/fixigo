{
  "name": "service-management-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "pre-commit": "./scripts/pre-commit.sh",
    "validate": "npm run type-check && npm run lint && npm run build",
    "performance-check": "npm run build && npm run start & sleep 10 && curl -s http://localhost:3000 > /dev/null && echo 'Performance check passed' && pkill -f 'next start'",
    "deploy": "next build && vercel --prod",
    "deploy:preview": "next build && vercel",
    "deploy:firebase": "next build && firebase deploy",
    "vercel:deploy": "vercel --prod",
    "vercel:preview": "vercel",
    "vercel:dev": "vercel dev",
    "vercel:link": "vercel link",
    "vercel:env": "vercel env pull .env.local",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules",
    "firebase:deploy:indexes": "firebase deploy --only firestore:indexes",
    "firebase:deploy:all": "firebase deploy --only firestore"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tanstack/react-table": "^8.21.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@vercel/speed-insights": "^1.2.0",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^11.10.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.525.0",
    "next": "15.4.1",
    "next-pwa": "^5.6.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-icons": "^5.5.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.4.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5"
  },
  "engines": {
    "node": "^18.0.0 || ^20.0.0"
  }
}
