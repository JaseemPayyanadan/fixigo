rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================
    // HELPER FUNCTIONS
    // ========================================
    
    // Authentication check
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Get current user data
    function getCurrentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Get current user role
    function getUserRole() {
      return getCurrentUser().role;
    }
    
    // Role-based checks
    function isShopAdmin() {
      return isAuthenticated() && getUserRole() == "shop_admin";
    }
    
    function isBranchAdmin() {
      return isAuthenticated() && getUserRole() == "branch_admin";
    }
    
    function isTechnician() {
      return isAuthenticated() && getUserRole() == "technician";
    }
    
    // Resource ownership checks
    function belongsToShop(shopId) {
      return getCurrentUser().shopId == shopId;
    }
    
    function belongsToBranch(branchId) {
      return getCurrentUser().branchId == branchId;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Onboarding-specific checks
    function isOnboardingUser() {
      return isAuthenticated() && !getCurrentUser().onboardingCompleted;
    }
    
    function isOnboardingCompleted() {
      return isAuthenticated() && getCurrentUser().onboardingCompleted;
    }
    
    function isOnboardingStepValid(step) {
      return step is number && step >= 1 && step <= 3;
    }
    
    function isOnboardingProgressValid(progress) {
      return progress is number && progress >= 0 && progress <= 100;
    }
    
    // Data validation helpers
    function isValidEmail(email) {
      return email is string && email.matches('^[^@]+@[^@]+\\.[^@]+$');
    }
    
    function isValidPhone(phone) {
      return phone is string && phone.matches('^[+]?[0-9]{10,15}$');
    }
    
    function sanitizeString(str) {
      return str is string && str.size() <= 1000;
    }
    
    function isValidGSTNumber(gst) {
      return gst is string && gst.matches('^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}Z[0-9A-Z]{1}$');
    }
    
    function isValidPinCode(pinCode) {
      return pinCode is string && pinCode.matches('^[0-9]{6}$');
    }
    
    function isValidShopName(name) {
      return name is string && name.size() >= 2 && name.size() <= 100;
    }
    
    function isValidOwnerName(name) {
      return name is string && name.size() >= 2 && name.size() <= 50;
    }
    
    function isValidAddress(address) {
      return address is string && address.size() >= 10 && address.size() <= 200;
    }
    
    function isValidCity(city) {
      return city is string && city.size() >= 2 && city.size() <= 50;
    }
    
    function isValidLocationData(address, city, pinCode) {
      return isValidAddress(address) && 
             isValidCity(city) && 
             isValidPinCode(pinCode);
    }
    
    function isValidBusinessData(shopName, ownerName, email, phone) {
      return isValidShopName(shopName) &&
             isValidOwnerName(ownerName) &&
             isValidEmail(email) &&
             isValidPhone(phone);
    }
    
    // ========================================
    // ONBOARDING COLLECTION
    // ========================================
    match /onboarding/{onboardingId} {
      // Users can only access their own onboarding data
      allow read, write: if isAuthenticated() && isOwner(onboardingId);
      
      // Allow creation during onboarding process (3 steps)
      allow create: if isOnboardingUser() && isOwner(onboardingId) &&
        request.resource.data.keys().hasAll(['userId', 'step', 'progress', 'data', 'createdAt', 'updatedAt']) &&
        request.resource.data.userId == request.auth.uid &&
        isOnboardingStepValid(request.resource.data.step) &&
        isOnboardingProgressValid(request.resource.data.progress) &&
        request.resource.data.data is map;
      
      // Allow updates during onboarding process
      allow update: if isOnboardingUser() && isOwner(onboardingId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['step', 'progress', 'data', 'updatedAt']) &&
        isOnboardingStepValid(request.resource.data.step) &&
        isOnboardingProgressValid(request.resource.data.progress);
      
      // Allow deletion when onboarding is completed
      allow delete: if isOnboardingCompleted() && isOwner(onboardingId);
    }
    
    // ========================================
    // ONBOARDING TEMPLATES COLLECTION
    // ========================================
    match /onboardingTemplates/{templateId} {
      // All authenticated users can read onboarding templates
      allow read: if isAuthenticated();
      
      // Only shop admins can create/update templates
      allow write: if isShopAdmin();
    }
    
    // ========================================
    // USERS COLLECTION
    // ========================================
    match /users/{userId} {
      // Users can read/write their own document
      allow read, write: if isAuthenticated() && isOwner(userId);
      
      // Allow users to create their own document during registration
      allow create: if isAuthenticated() && isOwner(userId) &&
        request.resource.data.keys().hasAll(['name', 'email', 'role', 'shopId', 'onboardingCompleted', 'status', 'createdAt', 'updatedAt']) &&
        isValidOwnerName(request.resource.data.name) &&
        isValidEmail(request.resource.data.email) &&
        request.resource.data.role in ['shop_admin', 'branch_admin', 'technician'] &&
        request.resource.data.shopId is string &&
        request.resource.data.onboardingCompleted is bool &&
        request.resource.data.status in ['active', 'inactive', 'suspended'];
      
      // Allow onboarding status updates with enhanced validation
      allow update: if isAuthenticated() && isOwner(userId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['onboardingCompleted', 'shopId', 'branchId', 'updatedAt']) &&
        request.resource.data.onboardingCompleted is bool &&
        (request.resource.data.shopId == null || request.resource.data.shopId is string);
      
      // Shop admins can read user documents in their shop
      allow read: if isShopAdmin() && belongsToShop(resource.data.shopId);
      
      // Branch admins can read user documents in their branch
      allow read: if isBranchAdmin() && belongsToBranch(resource.data.branchId);
    }
    
    // ========================================
    // SHOPS COLLECTION
    // ========================================
    match /shops/{shopId} {
      // Shop admins can manage their own shop
      allow read, write: if isShopAdmin() && belongsToShop(shopId);
      
      // Branch admins can read their shop document
      allow read: if isBranchAdmin() && belongsToShop(shopId);
      
      // Technicians can read their shop document
      allow read: if isTechnician() && belongsToShop(shopId);
      
      // Enhanced shop creation with comprehensive validation
      allow create: if isOnboardingUser() && isOwner(shopId) &&
        request.resource.data.keys().hasAll(['name', 'address', 'phone', 'email', 'ownerId', 'status', 'createdAt', 'updatedAt']) &&
        isValidBusinessData(request.resource.data.name, request.resource.data.ownerName, request.resource.data.email, request.resource.data.phone) &&
        isValidAddress(request.resource.data.address) &&
        request.resource.data.ownerId == request.auth.uid &&
        request.resource.data.status in ['active', 'inactive'] &&
        (request.resource.data.gstNumber == null || isValidGSTNumber(request.resource.data.gstNumber));
      
      // Allow shop updates during onboarding with enhanced validation
      allow update: if isOnboardingUser() && isOwner(shopId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['name', 'address', 'phone', 'email', 'gstNumber', 'updatedAt']) &&
        isValidShopName(request.resource.data.name) &&
        isValidAddress(request.resource.data.address) &&
        isValidPhone(request.resource.data.phone) &&
        isValidEmail(request.resource.data.email) &&
        (request.resource.data.gstNumber == null || isValidGSTNumber(request.resource.data.gstNumber));
      
      // Allow completed users to update their shop
      allow update: if isOnboardingCompleted() && isOwner(shopId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['name', 'address', 'phone', 'email', 'gstNumber', 'status', 'updatedAt']) &&
        isValidShopName(request.resource.data.name) &&
        isValidAddress(request.resource.data.address) &&
        isValidPhone(request.resource.data.phone) &&
        isValidEmail(request.resource.data.email) &&
        (request.resource.data.gstNumber == null || isValidGSTNumber(request.resource.data.gstNumber)) &&
        request.resource.data.status in ['active', 'inactive'];
      
      // ========================================
      // BRANCHES SUBCOLLECTION
      // ========================================
      match /branches/{branchId} {
        // Shop admins can manage all branches in their shop
        allow read, write, delete: if isShopAdmin() && belongsToShop(shopId);
        
        // Branch admins can read/write their own branch
        allow read, write: if isBranchAdmin() && belongsToBranch(branchId);
        
        // Technicians can read branches in their shop
        allow read: if isTechnician() && belongsToShop(shopId);
        
        // Allow creation by shop admins for their shop
        allow create: if isShopAdmin() && belongsToShop(shopId) &&
          request.resource.data.keys().hasAll(['name', 'address', 'phone', 'email', 'status', 'managerId', 'shopId', 'createdAt', 'updatedAt']) &&
          isValidShopName(request.resource.data.name) &&
          isValidAddress(request.resource.data.address) &&
          isValidPhone(request.resource.data.phone) &&
          isValidEmail(request.resource.data.email) &&
          request.resource.data.status in ['active', 'inactive', 'maintenance'] &&
          request.resource.data.managerId is string &&
          request.resource.data.shopId == shopId;
        
        // ========================================
        // TECHNICIANS SUBCOLLECTION
        // ========================================
        match /technicians/{technicianId} {
          // Shop admins can manage technicians in their shop
          allow read, write, delete: if isShopAdmin() && belongsToShop(shopId);
          
          // Branch admins can manage technicians in their branch
          allow read, write, delete: if isBranchAdmin() && belongsToBranch(branchId);
          
          // Technicians can read their own profile
          allow read: if isTechnician() && isOwner(technicianId);
          
          // Technicians can update their own profile
          allow update: if isTechnician() && isOwner(technicianId) &&
            request.resource.data.diff(resource.data).affectedKeys().hasAny(['name', 'email', 'phone', 'skills', 'status', 'bio', 'specializations', 'updatedAt']) &&
            isValidOwnerName(request.resource.data.name) &&
            isValidEmail(request.resource.data.email) &&
            isValidPhone(request.resource.data.phone);
          
          // Allow creation with validation
          allow create: if (isShopAdmin() && belongsToShop(shopId)) || (isBranchAdmin() && belongsToBranch(branchId)) &&
            request.resource.data.keys().hasAll(['name', 'email', 'phone', 'role', 'shopId', 'branchId', 'skills', 'status', 'createdAt', 'updatedAt']) &&
            isValidOwnerName(request.resource.data.name) &&
            isValidEmail(request.resource.data.email) &&
            isValidPhone(request.resource.data.phone) &&
            request.resource.data.role == "technician" &&
            request.resource.data.shopId == shopId &&
            request.resource.data.branchId == branchId &&
            request.resource.data.status in ['active', 'inactive'];
        }
        
        // ========================================
        // SERVICES SUBCOLLECTION
        // ========================================
        match /services/{serviceId} {
          // Shop admins can manage services in their shop
          allow read, write, delete: if isShopAdmin() && belongsToShop(shopId);
          
          // Branch admins can manage services in their branch
          allow read, write, delete: if isBranchAdmin() && belongsToBranch(branchId);
          
          // Technicians can read services in their branch
          allow read: if isTechnician() && belongsToBranch(branchId);
          
          // Technicians can update services they can access
          allow update: if isTechnician() && belongsToBranch(branchId) &&
            request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'updatedAt', 'notes', 'assignedTechnicianId', 'estimatedCompletion', 'actualCompletion', 'workNotes', 'partsUsed', 'customerFeedback', 'qualityScore']);
          
          // Allow creation with validation
          allow create: if (isShopAdmin() && belongsToShop(shopId)) || (isBranchAdmin() && belongsToBranch(branchId)) &&
            request.resource.data.keys().hasAll(['name', 'description', 'customer', 'device', 'status', 'priority', 'shopId', 'branchId', 'price', 'estimatedDuration', 'createdAt', 'updatedAt']) &&
            isValidShopName(request.resource.data.name) &&
            request.resource.data.customer is map &&
            request.resource.data.device is map &&
            request.resource.data.status in ['pending', 'in_progress', 'completed', 'cancelled', 'on_hold', 'awaiting_parts', 'ready_for_pickup', 'quality_check'] &&
            request.resource.data.priority in ['low', 'medium', 'high', 'urgent'] &&
            request.resource.data.shopId == shopId &&
            request.resource.data.branchId == branchId &&
            request.resource.data.price is number && request.resource.data.price >= 0 &&
            request.resource.data.estimatedDuration is number && request.resource.data.estimatedDuration > 0;
        }
        
        // ========================================
        // INVOICES SUBCOLLECTION
        // ========================================
        match /invoices/{invoiceId} {
          // Shop admins can manage invoices in their shop
          allow read, write, delete: if isShopAdmin() && belongsToShop(shopId);
          
          // Branch admins can manage invoices in their branch
          allow read, write, delete: if isBranchAdmin() && belongsToBranch(branchId);
          
          // Technicians can read invoices for services they can access
          allow read: if isTechnician() && belongsToBranch(branchId);
          
          // Allow creation with validation
          allow create: if (isShopAdmin() && belongsToShop(shopId)) || (isBranchAdmin() && belongsToBranch(branchId)) &&
            request.resource.data.keys().hasAll(['serviceId', 'customerName', 'customerEmail', 'customerPhone', 'amount', 'tax', 'total', 'status', 'paymentStatus', 'dueDate', 'shopId', 'branchId', 'items', 'createdAt', 'updatedAt']) &&
            request.resource.data.serviceId is string &&
            isValidOwnerName(request.resource.data.customerName) &&
            isValidEmail(request.resource.data.customerEmail) &&
            isValidPhone(request.resource.data.customerPhone) &&
            request.resource.data.amount is number && request.resource.data.amount >= 0 &&
            request.resource.data.tax is number && request.resource.data.tax >= 0 &&
            request.resource.data.total is number && request.resource.data.total >= 0 &&
            request.resource.data.status in ['draft', 'sent', 'paid', 'overdue', 'cancelled'] &&
            request.resource.data.paymentStatus in ['pending', 'paid', 'failed', 'partial', 'refunded'] &&
            request.resource.data.shopId == shopId &&
            request.resource.data.branchId == branchId &&
            request.resource.data.items is list &&
            request.resource.data.dueDate is timestamp;
          
          // Allow updates with validation
          allow update: if (isShopAdmin() && belongsToShop(shopId)) || (isBranchAdmin() && belongsToBranch(branchId)) &&
            request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'paymentStatus', 'updatedAt', 'items', 'subtotal', 'tax', 'total', 'discount', 'paymentMethod', 'paymentDate']) &&
            request.resource.data.status in ['draft', 'sent', 'paid', 'overdue', 'cancelled'] &&
            request.resource.data.paymentStatus in ['pending', 'paid', 'failed', 'partial', 'refunded'];
        }
        
        // ========================================
        // TASKS SUBCOLLECTION
        // ========================================
        match /tasks/{taskId} {
          // Shop admins can manage tasks in their shop
          allow read, write, delete: if isShopAdmin() && belongsToShop(shopId);
          
          // Branch admins can manage tasks in their branch
          allow read, write, delete: if isBranchAdmin() && belongsToBranch(branchId);
          
          // Technicians can access tasks assigned to them
          allow read, write: if isTechnician() && resource.data.assignedTechnicianId == request.auth.uid;
          
          // Allow creation with validation
          allow create: if (isShopAdmin() && belongsToShop(shopId)) || (isBranchAdmin() && belongsToBranch(branchId)) &&
            request.resource.data.keys().hasAll(['title', 'description', 'status', 'priority', 'assignedTechnicianId', 'dueDate', 'shopId', 'branchId', 'createdAt', 'updatedAt']) &&
            sanitizeString(request.resource.data.title) && request.resource.data.title.size() > 0 &&
            request.resource.data.status in ['pending', 'in_progress', 'completed', 'cancelled', 'on_hold'] &&
            request.resource.data.priority in ['low', 'medium', 'high', 'urgent'] &&
            request.resource.data.assignedTechnicianId is string &&
            request.resource.data.shopId == shopId &&
            request.resource.data.branchId == branchId &&
            request.resource.data.dueDate is timestamp;
        }
      }
    }
    
    // ========================================
    // ONBOARDING PROGRESS COLLECTION
    // ========================================
    match /onboardingProgress/{progressId} {
      // Users can only access their own onboarding progress
      allow read, write: if isAuthenticated() && isOwner(progressId);
      
      // Allow creation during onboarding (3 steps)
      allow create: if isOnboardingUser() && isOwner(progressId) &&
        request.resource.data.keys().hasAll(['userId', 'currentStep', 'totalSteps', 'completedSteps', 'progress', 'data', 'createdAt', 'updatedAt']) &&
        request.resource.data.userId == request.auth.uid &&
        isOnboardingStepValid(request.resource.data.currentStep) &&
        request.resource.data.totalSteps is number && request.resource.data.totalSteps == 3 &&
        request.resource.data.completedSteps is list &&
        isOnboardingProgressValid(request.resource.data.progress);
      
      // Allow updates during onboarding
      allow update: if isOnboardingUser() && isOwner(progressId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['currentStep', 'completedSteps', 'progress', 'data', 'updatedAt']) &&
        isOnboardingStepValid(request.resource.data.currentStep) &&
        isOnboardingProgressValid(request.resource.data.progress);
      
      // Allow deletion when onboarding is completed
      allow delete: if isOnboardingCompleted() && isOwner(progressId);
    }
    
    // ========================================
    // LOCATION SUGGESTIONS CACHE
    // ========================================
    match /locationCache/{cacheId} {
      // All authenticated users can read cached location data
      allow read: if isAuthenticated();
      
      // Only allow writes during onboarding or by shop admins
      allow write: if isOnboardingUser() || isShopAdmin();
    }
    
    // ========================================
    // LOCATION VALIDATION COLLECTION
    // ========================================
    match /locationValidation/{validationId} {
      // Allow read access for location validation
      allow read: if isAuthenticated();
      
      // Allow writes during onboarding for location validation
      allow write: if isOnboardingUser() && isOwner(validationId);
    }
    
    // ========================================
    // ONBOARDING SESSION COLLECTION
    // ========================================
    match /onboardingSessions/{sessionId} {
      // Users can only access their own onboarding sessions
      allow read, write: if isAuthenticated() && isOwner(sessionId);
      
      // Allow creation during onboarding
      allow create: if isOnboardingUser() && isOwner(sessionId) &&
        request.resource.data.keys().hasAll(['userId', 'step', 'data', 'startedAt', 'updatedAt']) &&
        request.resource.data.userId == request.auth.uid &&
        isOnboardingStepValid(request.resource.data.step) &&
        request.resource.data.data is map;
      
      // Allow updates during onboarding
      allow update: if isOnboardingUser() && isOwner(sessionId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['step', 'data', 'updatedAt']) &&
        isOnboardingStepValid(request.resource.data.step);
      
      // Allow deletion when onboarding is completed
      allow delete: if isOnboardingCompleted() && isOwner(sessionId);
    }
    
    // ========================================
    // TECHNICIANS COLLECTION (ROOT LEVEL)
    // ========================================
    match /technicians/{technicianId} {
      // Shop admins can manage technicians in their shop
      allow read, write, delete: if isShopAdmin() && belongsToShop(resource.data.shopId);
      
      // Branch admins can manage technicians in their branch
      allow read, write, delete: if isBranchAdmin() && belongsToBranch(resource.data.branchId);
      
      // Technicians can read their own profile
      allow read: if isTechnician() && resource.data.uid == request.auth.uid;
      
      // Technicians can update their own profile
      allow update: if isTechnician() && resource.data.uid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['name', 'email', 'phone', 'skills', 'status', 'bio', 'specializations', 'updatedAt']) &&
        isValidOwnerName(request.resource.data.name) &&
        isValidEmail(request.resource.data.email) &&
        isValidPhone(request.resource.data.phone);
      
      // Allow creation with validation
      allow create: if (isShopAdmin() && belongsToShop(request.resource.data.shopId)) || (isBranchAdmin() && belongsToBranch(request.resource.data.branchId)) &&
        request.resource.data.keys().hasAll(['uid', 'name', 'email', 'phone', 'role', 'shopId', 'branchId', 'skills', 'status', 'createdAt', 'updatedAt']) &&
        isValidOwnerName(request.resource.data.name) &&
        isValidEmail(request.resource.data.email) &&
        isValidPhone(request.resource.data.phone) &&
        request.resource.data.role == "technician" &&
        request.resource.data.status in ['active', 'inactive'];
    }
    
    // ========================================
    // DEFAULT: DENY ALL OTHER ACCESS
    // ========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
} 