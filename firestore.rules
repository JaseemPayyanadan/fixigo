rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Temporary migration access - allow all access during migration
    function isMigrationMode() {
      return true; // Temporarily allow all access for migration
    }

    // Users collection
    match /users/{userId} {
      allow read, write, delete: if isMigrationMode();
    }

    // Shops collection
    match /shops/{shopId} {
      allow read, write, delete: if isMigrationMode();
    }

    // Branches collection
    match /branches/{branchId} {
      allow read, write, delete: if isMigrationMode();
    }

    // Technicians collection
    match /technicians/{technicianId} {
      allow read, write, delete: if isMigrationMode();
    }

    // Services collection
    match /services/{serviceId} {
      allow read, write, delete: if isMigrationMode();
    }

    // Tasks collection
    match /tasks/{taskId} {
      allow read, write, delete: if isMigrationMode();
    }

    // Customers collection
    match /customers/{customerId} {
      allow read, write, delete: if isMigrationMode();
    }

    // Parts collection
    match /parts/{partId} {
      allow read, write, delete: if isMigrationMode();
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read, write, delete: if isMigrationMode();
    }

    // Audit logs collection (read-only for admins)
    match /audit_logs/{logId} {
      allow read, write, delete: if isMigrationMode();
    }

    // Legacy subcollections (for backward compatibility during migration)
    match /shops/{shopId}/branches/{branchId} {
      allow read, write, delete: if isMigrationMode();
    }

    match /shops/{shopId}/branches/{branchId}/services/{serviceId} {
      allow read, write, delete: if isMigrationMode();
    }

    match /shops/{shopId}/branches/{branchId}/tasks/{taskId} {
      allow read, write, delete: if isMigrationMode();
    }
  }
}
